<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:vm="clr-namespace:Indiko.Maui.Controls.Chat.Sample.ViewModels"
             xmlns:utils="clr-namespace:Indiko.Maui.Controls.Chat.Sample.Utils"
             xmlns:idk="clr-namespace:Indiko.Maui.Controls.Chat;assembly=Indiko.Maui.Controls.Chat"
             x:Class="Indiko.Maui.Controls.Chat.Sample.MainPage"
			 x:DataType="vm:MainPageViewModel"
             BackgroundColor="White"
             Title="ChatView Sample">

    <ContentPage.ToolbarItems>
        <!-- Simulates an incoming ("other") message so the receive-while-scrolled-up
             behaviour can be exercised without a backend. -->
        <ToolbarItem Text="Receive" Command="{Binding SimulateIncomingCommand}" />
        <!-- Posts an own + incoming voice note to exercise the audio cells. -->
        <ToolbarItem Text="Voice" Command="{Binding SendVoiceNoteCommand}" />
        <!-- Posts captioned images to exercise media captions. -->
        <ToolbarItem Text="ImgCap" Command="{Binding SendCaptionedImageCommand}" />
        <!-- Posts a text message with a link-preview card. -->
        <ToolbarItem Text="Link" Command="{Binding SendLinkPreviewCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*, 2, Auto">

        <idk:ChatView Grid.Row="0" x:Name="chatView"
    
            OwnMessageBackgroundColor="{StaticResource Primary}" 
            OwnMessageTextColor="{StaticResource White}"
            OtherMessageBackgroundColor="{StaticResource Secondary}"
            OtherMessageTextColor="{StaticResource Black}"
            DateTextColor="{StaticResource Gray500}"
            DateTextFontSize="14"
            MessageTimeTextColor="{StaticResource Gray200}"
            NewMessagesSeperatorTextColor="{StaticResource Primary}"
            NewMessagesSeperatorFontSize="16"
            NewMessagesSeperatorText="New Messages"
            AvatarTextColor="{StaticResource White}"
            AvatarBackgroundColor="{StaticResource Tertiary}"
            Messages="{Binding ChatMessages}"
            EmojiReactionFontSize="14"
            EmojiReactionTextColor="{StaticResource Primary}"
            ReplyMessageBackgroundColor="{StaticResource Tertiary}"
            ReplyMessageTextColor="{StaticResource White}"
            EnableJumpToRepliedMessage="True"
            RepliedMessageHighlightColor="#80FFD54F"
            LoadMoreMessagesCommand="{Binding LoadOlderMessagesCommand}"
            ScrolledCommand="{Binding ScrolledCommand}"
            AvatarTappedCommand="{Binding AvatarTappedCommand}"
            MessageTappedCommand="{Binding MessageTappedCommand}"
            EmojiReactionTappedCommand="{Binding EmojiReactionTappedCommand}"
            SendIcon="send.png"
            DeliveredIcon="check.png"
            ReadIcon="read.png"
            ScrollToFirstNewMessage="False"
            ScrollToLastMessage="True"
            ShowNewMessagesSeperator="True"
            ScrolledToLastMessageCommand="{Binding ScrolledToLastMessageCommand}"
            ShowScrollToBottomButton="True"
            ScrollToBottomButtonBackgroundColor="{StaticResource Primary}"
            ScrollToBottomButtonIconColor="{StaticResource White}"
            ScrollToBottomButtonSize="46"
            ShowScrollToBottomBadge="True"
            ScrollToBottomBadgeBackgroundColor="{StaticResource Tertiary}"
            ScrollToBottomBadgeTextColor="{StaticResource White}"
            ScrollToBottomBadgeFontSize="11"
            SystemMessageBackgroundColor="{StaticResource Yellow300Accent}"
            SystemMessageTextColor="{StaticResource Tertiary}"
            SystemMessageFontSize="14"
            LongPressedCommand="{Binding LongPressedCommand}"
            ContextMenuDividerColor="{StaticResource Gray300}"
            ContextMenuTextColor="{StaticResource Gray600}"
            ContextMenuBackgroundColor="{StaticResource White}">

        </idk:ChatView>

        <Rectangle Grid.Row="1" BackgroundColor="{StaticResource Tertiary}" MinimumHeightRequest="2"></Rectangle>

        <!-- Optional built-in composer. Input-only: it raises SendCommand with a ChatComposeResult;
             the view model builds + persists the ChatMessage. ReplyingTo two-way binds so the swipe /
             context-menu "Reply" flow populates the composer's reply banner. -->
        <idk:ChatInputView Grid.Row="2"
            BackgroundColor="{StaticResource White}"
            Placeholder="Type a message..."
            AccentColor="{StaticResource Primary}"
            TextColor="{StaticResource Tertiary}"
            EntryBackgroundColor="{StaticResource Secondary}"
            ReplyBarBackgroundColor="{StaticResource Secondary}"
            ReplyBarTextColor="{StaticResource Tertiary}"
            EnableAttachments="True"
            EnableVoiceRecording="True"
            EnableEmojiPicker="True"
            InputFontSize="16"
            IconFontSize="18"
            ReplyingTo="{Binding ReplyingTo, Mode=TwoWay}"
            SendCommand="{Binding SendComposedCommand}">
            <!-- Custom icons (optional) — falls back to built-in glyphs when not set. -->
            <idk:ChatInputView.SendIcon>
                <FontImageSource Glyph="{x:Static utils:FontAwesome.Paperplane}" FontFamily="{x:Static utils:FontAwesome.FONTNAME}" Color="{StaticResource Primary}" Size="20" />
            </idk:ChatInputView.SendIcon>
            <idk:ChatInputView.AttachIcon>
                <FontImageSource Glyph="{x:Static utils:FontAwesome.Paperclip}" FontFamily="{x:Static utils:FontAwesome.FONTNAME}" Color="{StaticResource Primary}" Size="20" />
            </idk:ChatInputView.AttachIcon>
        </idk:ChatInputView>
    </Grid>


</ContentPage>
